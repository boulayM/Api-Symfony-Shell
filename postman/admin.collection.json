{
  "info": {
    "_postman_id": "024ebde5-83bc-4e08-8b76-a9bfc18710f7",
    "name": "Api-Symfony-Shell - Admin Flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "CSRF - Issue token",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/csrf"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const csrf = pm.cookies.get('XSRF-TOKEN');",
              "pm.test('csrf cookie available', function () {",
              "  pm.expect(csrf).to.be.a('string').and.not.empty;",
              "});",
              "pm.collectionVariables.set('csrfToken', csrf);"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Login admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Admin - List users",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/admin/users?page=1&limit=5"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('users payload has pagination keys', function () {",
              "  pm.expect(body).to.have.property('data');",
              "  pm.expect(body).to.have.property('page');",
              "  pm.expect(body).to.have.property('limit');",
              "  pm.expect(body).to.have.property('total');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Admin - List audit logs",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/admin/audit-logs?page=1&limit=5"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('audit payload has pagination keys', function () {",
              "  pm.expect(body).to.have.property('data');",
              "  pm.expect(body).to.have.property('page');",
              "  pm.expect(body).to.have.property('limit');",
              "  pm.expect(body).to.have.property('total');",
              "});"
            ]
          }
        }
      ]
    },
