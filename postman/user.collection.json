{
  "info": {
    "_postman_id": "e8465dd8-cd17-4936-b6cf-dbd2068d8d4c",
    "name": "Api-Symfony-Shell - User Flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "CSRF - Issue token",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/csrf"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const csrf = pm.cookies.get('XSRF-TOKEN');",
              "pm.test('csrf cookie available', function () {",
              "  pm.expect(csrf).to.be.a('string').and.not.empty;",
              "});",
              "pm.collectionVariables.set('csrfToken', csrf);"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Login user",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Me",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/auth/me"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('user email matches fixture', function () {",
              "  pm.expect(body.user.email).to.eql(pm.environment.get('userEmail'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Public - Update profile",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-CSRF-TOKEN",
            "value": "{{csrfToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"UserFlow\",\n  \"lastName\": \"Newman\"\n}"
        },
        "url": "{{baseUrl}}/api/public/users/me"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Refresh",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/auth/refresh"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Logout all",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/auth/logout-all"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "csrfToken",
      "value": ""
    }
  ]
}
